			</rect>

			<!-- move pagination panel down one row -->
			<rect depth="2" pos="540,-43" width="104" height="43" disableautobackground="true" visible="{paging_visible}">
				<pager name="pager" pos="4,-6" contents_parent="windowSkillList"/>
