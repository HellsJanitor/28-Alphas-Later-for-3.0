<configs>
    <!-- Make Encumberence Debuff percentage lower to accomodate more locked inventory slots -->
	<set xpath="/buffs/buff[@name='buffEncumberedInv']/effect_group/triggered_effect[@cvar='$encumbranceEffect'][@value='0.026']/@value">0.02</set>
	<set xpath="/buffs/buff[@name='buffDrugSteroids']/effect_group/passive_effect[@name='CarryCapacity'][@operation='base_set']/@operation">base_add</set>
	
	<append xpath="/buffs/buff[@name='buffStatusCheck01']">
		<effect_group>
			<triggered_effect trigger="onSelfBuffUpdate" action="AddBuff" buff="buffBackpackLevel"/>
		</effect_group>
	</append>
	
	<append xpath="/buffs">
		<buff name="buffBackpackLevel" hidden="true">
			<stack_type value="ignore"/>
			<duration value="0"/>		
			
			<effect_group>
				<passive_effect name="BagSize" operation="base_add" level="1" value="10"/>
				<requirement name="CVarCompare" cvar="backpackTier" operation="EQ" value="1"/>
			</effect_group>

			<effect_group>
				<passive_effect name="BagSize" operation="base_add" level="1" value="20"/>
				<requirement name="CVarCompare" cvar="backpackTier" operation="EQ" value="2"/>
			</effect_group>	

			<effect_group>
				<passive_effect name="BagSize" operation="base_add" level="1" value="30"/>
				<requirement name="CVarCompare" cvar="backpackTier" operation="EQ" value="3"/>
			</effect_group>	
		</buff>
	</append>
</configs>