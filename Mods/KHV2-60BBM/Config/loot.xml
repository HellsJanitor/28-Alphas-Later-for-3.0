<configs>
    <!-- Make player dropped bags bigger to accomodate new size-->
	<set xpath="/lootcontainers/lootcontainer[@name='playerBackpack']/@size">10,10</set>

	<append xpath="/lootcontainers/lootgroup[@name='groupT1Clothing']">
		<item name="backpackUpgradeTier1" loot_prob_template="low" tags="backpackUpgradeTier1"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='groupT2Clothing']">
		<item name="backpackUpgradeTier2" loot_prob_template="low" tags="backpackUpgradeTier2"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='groupT3Clothing']">
		<item name="backpackUpgradeTier3" loot_prob_template="veryLow" tags="backpackUpgradeTier3"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='modArmorT1']">
		<item name="backpackUpgradeTier1" tags="backpackUpgradeTier1"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='modArmorT2']">
		<item name="backpackUpgradeTier2" tags="backpackUpgradeTier2"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='modArmorT3']">
		<item name="backpackUpgradeTier3" tags="backpackUpgradeTier3"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='schematicsModsAndGeneralT0']">
		<item name="schematicBackpackTier1"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='schematicsModsAndGeneralT1']">
		<item name="schematicBackpackTier2"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='schematicsModsAndGeneralT2']">
		<item name="schematicBackpackTier3"/>
	</append>
</configs>