<configs>
	<!-- update the overall backpack size -->
	<set xpath="/windows/window[@name='windowBackpack']/@width">604</set>
	<set xpath="/windows/window[@name='windowBackpack']/@height">373</set>

	<!-- increase the content rect size -->
	<set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/@height">330</set>

	<!-- adjust backpack grid -->
	<set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/@rows">6</set>
	<set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/@cols">10</set>
	<set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/@cell_height">60</set>
	<set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/@cell_width">60</set>

	<!-- resize backpack background -->
	<set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/sprite[@name='backgroundMain']/@width">601</set>
	<set xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/sprite[@name='backgroundMain']/@height">363</set>

	<!-- adjust windowLooting to match the size of the new player dropped backpack container -->
	<set xpath="/windows/window[@name='windowLooting']/rect[@name='content']/grid[@name='queue']/@rows">10</set>
	<set xpath="/windows/window[@name='windowLooting']/rect[@name='content']/grid[@name='queue']/@cols">10</set>

	<!-- replace vanilla backpack slot template -->
	<remove xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']/item_stack"/>

	<append xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/grid[@name='inventory']">
		<kh60_backpack_item_stack name="0"/>
	</append>
	
	<insertBefore xpath="/windows/window[@name='windowBackpack']/rect[@name='content']/sprite[@name='backgroundMain']">
		<sprite name="futureBagBackdrop" depth="7" pos="0,-183" width="601" height="180" color="[darkGrey]" type="sliced" globalopacity="true"/>
	</insertBefore>

</configs>