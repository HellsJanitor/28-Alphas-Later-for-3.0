<config>
	<prepend xpath="/lootcontainers/lootprobtemplates">
		<lootprobtemplate name="extremelyLow">
			<loot level="1,999999" prob=".01"/>
		</lootprobtemplate>
	</prepend>
	<insertafter xpath="//lootqualitytemplates/lootqualitytemplate[@name='qualQ1Template']">
		<!-- *** legendary quality template *** -->
		<lootqualitytemplate name="qualLegendaryTemplate">
			<qualitytemplate level="1,999999" default_quality="6">
				<loot quality="6" prob="1"/>
			</qualitytemplate>
		</lootqualitytemplate>
		
		<!-- *** basic (hoe) quality template *** -->
		<lootqualitytemplate name="qualBasicTemplate">
			<qualitytemplate level="1,999999" default_quality="1">
				<loot quality="1" prob="1"/>
			</qualitytemplate>
		</lootqualitytemplate>
	</insertafter>
	
	<!-- *** adjustments for research paper in loot -->
	<set xpath="/lootcontainers/lootgroup/item[@group='skillMagazines']/@loot_prob_template">high</set>
	
	<!-- *** portable device batteries in loot -->
	<append xpath="//lootgroup[@name='groupElectricalDevices']">
		<item name="resourceNiCdBattery" count="1,2" loot_prob_template="veryLow"/>
	</append>
	
	<append xpath="//lootgroup[@name='groupMoPowerShelves01']">
		<item name="resourceNiCdBattery" count="1,2" loot_prob_template="low"/>
	</append>
	
	<append xpath="//lootgroup[contains(@name,'Power01') or (contains(@name,'Power02')) or (contains(@name,'Power03')) or (contains(@name,'Power04'))]">
		<item name="resourceNiCdBattery" count="1,2" loot_prob_template="low"/>
	</append>
	
	<!-- *** coffee flask and sports bottle -->
	<append xpath="/lootcontainers/lootgroup[@name='groupShamwayShelves02']">
		<item name="toolInsulatedFlask" count="1" loot_prob_template="veryLow"/>
		<item name="toolSportsBottle" count="1" loot_prob_template="veryLow"/>
	</append>
	
	<append xpath="/lootcontainers/lootgroup[@name='groupCupboard02']">
		<item name="toolCanteen" count="1" loot_prob_template="extremelyLow"/>
		<item name="toolInsulatedFlask" count="1" loot_prob_template="extremelyLow"/>
		<item name="toolSportsBottle" count="1" loot_prob_template="extremelyLow"/>
	</append>
	
	<!-- *** adds cotton seeds to loot -->
	<append xpath="//lootgroup[@name='seedsNoFlowers']">
		<item name="plantedCotton1"/>
	</append>

	<!-- *** lowers chance of seeds in junk -->
	<set xpath="/lootcontainers/lootgroup[@name='groupJunk01']/item[@group='seeds']/@loot_prob_template">veryLow</set>
	<set xpath="/lootcontainers/lootgroup[@name='groupJunkNoBMats01']/item[@group='seeds']/@loot_prob_template">veryLow</set>
	
	<!-- *** reduce brass in loot -->
	<set xpath="/lootcontainers/lootgroup[@name='groupScrapUncommon']/item[@name='resourceScrapBrass']/@count">5,25</set>
	<set xpath="/lootcontainers/lootgroup[@name='groupWorkbenchLoot01']/item[@name='resourceScrapBrass']/@count">1,10</set>
	<set xpath="/lootcontainers/lootgroup[@name='groupForge01']/item[@name='resourceScrapBrass']/@count">5,10</set>
	<set xpath="/lootcontainers/lootgroup[@name='twitch_natresources2']/item[@name='resourceScrapBrass']/@count">1,3</set>
	
	<!-- *** remove jars from loot -->
	<remove xpath="/lootcontainers/lootgroup/item[@name='drinkJarEmpty']"/>
	
	<!-- *** remove drinks from loot -->
	<remove xpath="/lootcontainers/lootgroup/item[contains(@name,'drink') or (contains(@name,'Drink')) and not (contains(@name,'Beer'))]"/>
	
