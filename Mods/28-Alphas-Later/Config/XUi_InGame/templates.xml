<HellsJanitor>
	
	<set xpath="/templates/skill_crafting_entry">
		<panel disableautobackground="true" controller="_28AlphasLater.UI.XUiC_SkillCraftingInfoEntry_Research, 28AL-Harmony" width="${width}" height="${height}" style="press, hover, scroll" color_bg_bought="140,130,100,255" color_bg_available="[lightGrey]" color_bg_locked="[darkGrey]" color_lbl_available="[white]" color_lbl_locked="[lightGrey]" color_lbl_nerfed="204,17,17" color_lbl_buffed="17,204,17" visible="{nothiddenbypager}">
			<!-- row backgrounds / selection -->
			<sprite depth="2" name="backgroundMain" sprite="menu_empty2px" pos="0,${-height}" height="2" color="[black]" type="sliced" fillcenter="false"/>
			<sprite depth="2" name="background" sprite="menu_empty3px" pos="2,1" width="${width-4}" height="${height}" color="[selectedColor]" type="sliced" globalopacity="true" fillcenter="false" visible="{show_selected}"/>
			<sprite depth="1" name="backgroundMainColor" sprite="menu_empty" pos="2,0" width="${width-4}" type="sliced" fillcenter="true" color="{color_bg}" visible="{hasentry}"/>

			<!-- left: icon + title -->
			<sprite depth="6" name="itemIcon" width="64" height="64" atlas="{iconatlas}" sprite="{itemicon}" pos="35,-35" pivot="center" foregroundlayer="true" color="{itemcolor}"/>
			<label depth="3" pos="77,-${Round(height/2,0)}" text="{text}" pivot="left" justify="center" width="423" font_size="28" color="{color_fg}" visible="{hasentry}"/>

			<!-- current quality bar/text (left) -->
			<sprite depth="3" name="durabilityBackground" width="60" height="10" sprite="menu_empty3px" color="[darkGrey]" type="sliced" pos="6,-60" foregroundlayer="true" visible="{showquality}"/>
			<filledsprite depth="4" name="durability" width="60" height="10" sprite="menu_empty2px" color="{currentqualitycolor}" fill="1" type="filled" pos="6,-60" foregroundlayer="true" visible="{showquality}"/>
			<label depth="7" name="stackValue" pos="-2,-45" width="70" height="28" text="{currentqualitytext}" font_size="26" effect="outline" justify="Center" visible="{showquality}"/>

			<!-- lock + completion check -->
			<sprite depth="12" pos="55,-55" style="icon30px" sprite="ui_game_symbol_lock" pivot="center" visible="{showlock}"/>
			<sprite depth="12" pos="610,-45" style="icon30px" sprite="ui_game_symbol_check" pivot="center" visible="{showcomplete}"/>

			<!-- RIGHT-SIDE PURCHASE CLUSTERS -->
			<!-- Quality items: cart as bg + RP cost + next-quality bar + "1/2" -->
			<rect name="rpClusterQuality" pos="${width-128},0" width="128" height="${height}" disableautobackground="true" visible="{notcompletequality}">
				<!-- cart background (behind everything in the cluster) -->
				<button depth="7" pos="96,-40" style="icon32px, press, hover" sprite="ui_game_symbol_shopping_cart" pivot="center" color="255,255,255,250"/>

				<!-- RP cost (top-right over cart) -->
				<label depth="13" pos="134,-14" width="80" height="24" text="{nextpoints}" font_size="28" pivot="right" justify="center" effect="outline"/>

				<!-- next-quality bar (middle-right over cart) -->
				<sprite depth="11" name="nextQualityBg" width="48" height="14" sprite="menu_empty3px" color="[darkGrey]" type="sliced" pos="122,-66" pivot="right" foregroundlayer="true"/>
				<filledsprite depth="12" name="nextQuality" width="48" height="14" sprite="menu_empty2px" color="{nextqualitycolor}" fill="1" type="filled" pos="122,-66" pivot="right" foregroundlayer="true"/>

				<!-- "1/2" (bottom-right over cart) -->
				<label depth="13" name="nextQualityText" pos="100,-66" width="80" height="20" text="{nextqualitytext}" font_size="22" pivot="right" justify="right" effect="outline"/>
			</rect>

			<!-- Non-quality items: cart bg + RP cost only -->
			<rect name="rpClusterNoQuality" pos="${width-128},0" width="128" height="${height}" disableautobackground="true" visible="{notcompletenoquality}">
				<button depth="7" pos="96,-40" style="icon32px, press, hover" sprite="ui_game_symbol_shopping_cart" pivot="center" color="255,255,255,250"/>
				<label depth="13" pos="134,-14" width="80" height="24" text="{nextpoints}" font_size="28" pivot="right" justify="center" effect="outline"/>
			</rect>

			<!-- Buy button (unchanged) -->
			<button depth="15" name="btnBuy" pos="${width-32},-${Round(height/2,0)}" width="16" height="16" style="icon32px, press, hover" sprite="ui_game_symbol_party" pivot="center"/><!--  tooltip="Purchase next tier for {nextpoints} RP" -->
		</panel>
	</set>
	
	<set xpath="/templates/dewcollector_stack/rect/sprite[@sprite='ui_game_symbol_water']/@sprite">ui_game_symbol_clock</set>
	
	<append xpath="/templates">
		<ingredient_row_narrow>
			<rect controller="IngredientEntry">
				<rect depth="2">
					<sprite depth="1" size="66,43" pos="0,0" color="[mediumGrey]" type="sliced"/>
					<sprite depth="2" size="71,47" pos="-3,2" color="[black]" type="sliced" sprite="menu_empty3px" fillcenter="false"/>
					<sprite depth="3" size="38,38" pos="33,-22" color="{itemicontint}" pivot="center" atlas="ItemIconAtlas" sprite="{itemicon}" foregroundlayer="true"/>
				</rect>
				<rect depth="2" pos="68,0">
					<sprite depth="1" size="236,43" pos="0,0" color="[mediumGrey]" type="sliced"/>
					<sprite depth="2" size="242,47" pos="-3,2" color="[black]" type="sliced" sprite="menu_empty3px" fillcenter="false"/>
					<label depth="3" size="230,26" pos="117,-23" color="[labelColor]" pivot="center" justify="center" font_size="26" text="{itemname}"/>
				</rect>
				<rect depth="2" pos="307,0">
					<sprite depth="1" size="140,43" pos="0,0" color="[mediumGrey]" type="sliced"/>
					<sprite depth="2" size="146,47" pos="-3,2" color="[black]" type="sliced" sprite="menu_empty3px" fillcenter="false"/>
					<label depth="3" size="120,26" pos="70,-23" color="[labelColor]" pivot="center" justify="center" font_size="26" text="{haveneedcount}"/>
				</rect>
			</rect>
		</ingredient_row_narrow>
		
		<oven_recipe_stack>
			<rect controller="RecipeStack" width="57" height="57" collider_scale="1.0">
				<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,3" width="63" height="63" color="[black]" type="sliced" fillcenter="false"/>
				<sprite name="background" color="[mediumGrey]" type="sliced" style="press" on_hover="true"/>
				<sprite depth="1" name="itemIcon" width="49" height="49" atlas="ItemIconAtlas" sprite="" pos="36,-28" pivot="center" foregroundlayer="true"/>
				<sprite depth="4" name="lockIcon" width="12" height="12" sprite="ui_game_symbol_hammer" pos="2,-2" visible="false" foregroundlayer="true"/>
				<label depth="4" name="count" pos="0,-38" width="55" height="18" text="Test" font_size="24" justify="right" effect="outline"/>
				<label depth="4" name="timer" pos="21,-24" width="55" height="19" font_size="24" justify="center" pivot="center" color="[beige]" effect="outline" effect_distance="1,1" effect_color="0,0,0,255"/>
				<sprite depth="2" name="overlay" width="57" height="57" color="32,32,32,128" type="sliced"/>
				<sprite depth="3" name="cancel" sprite="ui_game_symbol_x" width="57" height="57" color="255,0,0,0" type="sliced" visible="false" foregroundlayer="true"/>
			</rect>
		</oven_recipe_stack>
		
		<recipe_output_header>
			<rect name="header" width="447" height="40">
				<rect depth="2" width="65" height="40">
					<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,0" width="71" height="40" color="[black]" type="sliced" fillcenter="false"/>
					<sprite color="[darkGrey]" type="sliced"/>
					<label depth="3" text="Item" pos="32,-21" height="26" font_size="26" color="[white]" justify="center" pivot="center"/>
				</rect>

				<rect depth="2" width="236" height="40" pos="68,0">
					<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,0" width="242" height="40" color="[black]" type="sliced" fillcenter="false"/>
					<sprite color="[darkGrey]" type="sliced"/>
					<label depth="3" text="Name" pos="117,-21" width="230" height="26" font_size="26" color="[white]" justify="center" pivot="center"/>
				</rect>

				<rect depth="2" width="140" height="40" pos="307,0">
					<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,0" width="146" height="40" color="[black]" type="sliced" fillcenter="false"/>
					<sprite color="[darkGrey]" type="sliced"/>
					<label depth="3" text="Count" pos="70,-21" width="120" height="26" font_size="26" color="[white]" justify="center" pivot="center"/>
				</rect>
			</rect>
		</recipe_output_header>
		
		<recipe_output_row>
			<rect name="row" width="447" height="42" controller="HJ.MultiOutputRecipes.XUiC_RecipeOutputEntry,28AL-Harmony">
				<rect depth="2" width="65" height="42">
					<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,6" width="71" height="44" color="[black]" type="sliced" fillcenter="false"/>
					<sprite color="[mediumGrey]" type="sliced"/>
					<sprite depth="2" name="icon" width="34" height="34" atlas="ItemIconAtlas" sprite="{itemicon}" color="{itemicontint}" pos="30,-18" pivot="center" foregroundlayer="true"/>
				</rect>

				<rect depth="2" width="236" height="42" pos="68,0">
					<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,6" width="242" height="44" color="[black]" type="sliced" fillcenter="false"/>
					<sprite color="[mediumGrey]" type="sliced"/>
					<label depth="3" name="name" pos="117,-18" width="230" height="26" font_size="26" color="[labelColor]" justify="center" pivot="center" text="{name}"/>
				</rect>

				<rect depth="2" width="140" height="42" pos="307,0">
					<sprite depth="2" name="backgroundMain" sprite="menu_empty3px" pos="-3,6" width="146" height="44" color="[black]" type="sliced" fillcenter="false"/>
					<sprite color="[mediumGrey]" type="sliced"/>
					<label depth="3" name="count" pos="70,-18" width="120" height="26" font_size="26" color="[labelColor]" justify="center" pivot="center" text="{count}"/>
				</rect>
			</rect>
		</recipe_output_row>
	</append>
</HellsJanitor>